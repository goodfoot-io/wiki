{
  "workspaces": {
    ".": {
      "entry": [".claude/**/*.{js,mjs,ts}", ".devcontainer/**/*.{js,mjs,ts}"],
      "project": [".claude/**/*.{js,mjs,ts}", ".devcontainer/**/*.{js,mjs,ts}"],
      "ignore": [".worktrees/**"]
    },
    "packages/*": {
      "entry": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.{ts,tsx}", "scripts/**/*.{js,ts}"],
      "project": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.{ts,tsx}", "scripts/**/*.{js,ts}"],
      "ignore": ["node_modules/**", "dist/**", "build/**", "test/fixtures/**"]
    }
  }
}
