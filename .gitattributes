# Enforce LF line endings in the repository on all platforms
* text=auto
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Resolve version conflicts automatically during merges by picking the highest semver
.claude-plugin/marketplace.json merge=json-version
plugins/*/.claude-plugin/plugin.json merge=json-version
