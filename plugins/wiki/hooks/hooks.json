{
  "description": "Validate wiki pages with `wiki check` after edits",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/wiki-check.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
